// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String    @unique
  username     String    @unique
  gender       String?
  role         String?
  password     String
  createdAt    DateTime  @default(now())
  resetOtp     String?
  otpExpiresAt DateTime?

  // ✅ Relations
  tables       Table[] // 1 waiter → many tables
  waiterOrders Order[] @relation("WaiterOrders") // waiter’s orders
  chefOrders   Order[] @relation("ChefOrders") // chef’s orders
}

model MenuItem {
  id             Int      @id @default(autoincrement())
  itemName       String
  category       String
  price          Float
  totalAvailable Int
  description    String?
  available      Boolean  @default(true)
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems OrderItem[] // ✅ One menu item → many order items

  @@map("menuItems")
}

model Table {
  id          Int      @id @default(autoincrement())
  tableNumber String
  capacity    Int
  waiterId    Int?
  waiter      User?    @relation(fields: [waiterId], references: [id])
  available   Boolean  @default(true) // ✅ Added availability flag
  status      String   @default("Available") // Waiter flow updates this
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders       Order[]
  reservations Reservation[]
  billings     Billing[]
}

model Order {
  id          Int      @id @default(autoincrement())
  waiterId    Int
  tableId     Int
  chefId      Int?
  billingId   Int? // 🔥 New field: each order belongs to one Billing
  totalAmount Float
  status      String   @default("Pending") // Pending | InProgress | Ready | Served | Paid
  createdAt   DateTime @default(now())

  // 🔗 Relations
  waiter     User        @relation("WaiterOrders", fields: [waiterId], references: [id])
  chef       User?       @relation("ChefOrders", fields: [chefId], references: [id])
  table      Table       @relation(fields: [tableId], references: [id])
  billing    Billing?     @relation(fields: [billingId], references: [id]) // 🔥 Newly added relation
  orderItems OrderItem[]
}

model OrderItem {
  id         Int   @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  quantity   Int
  price      Float
  subTotal   Float

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  status String @default("InProgress")  // InProgress | Ready | Served
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model AIPrompt {
  id        Int      @id @default(autoincrement())
  type      String   // item_description, menu_import, etc.
  prompt    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Reservation {
  id           Int      @id @default(autoincrement())
  guestName    String
  phone        String
  numPeople    Int
  dateTime     DateTime
  specialNotes String?
  status       String   @default("Pending") // Pending, Accepted, Rejected
  preOrders    Json?
  tableId      Int?
  table        Table?   @relation(fields: [tableId], references: [id])
  createdAt    DateTime @default(now())
}

model Billing {
  id        Int       @id @default(autoincrement())
  tableId   Int
  status    String    @default("Unbilled") // Unbilled | Billed
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  table  Table   @relation(fields: [tableId], references: [id])
  orders Order[]
}
