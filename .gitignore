# ==================================================

frontend/dist/
frontend/.angular/
frontend/.expo/
frontend/coverage/
frontend/.cache/
frontend/tmp/
frontend/out-tsc/

# Angular environment files (if used for secrets)
frontend/src/environments/environment*.ts

