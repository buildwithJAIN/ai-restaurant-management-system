# Node dependencies
node_modules/
**/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (NEVER commit real secrets)
.env
.env.*
*.local

# OS files
.DS_Store
Thumbs.db

# IDE / Editors
.vscode/
.idea/

